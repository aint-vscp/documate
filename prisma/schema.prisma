// DocuMate Database Schema
// Prisma ORM for off-chain data (subscriptions, verification, admin)
// On-chain data lives on KILT/Asset Hub - this is for operational data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER & SUBSCRIPTION MANAGEMENT
// ============================================================

model User {
  id              String   @id @default(cuid())
  walletAddress   String   @unique
  did             String?  @unique // KILT DID if linked
  web3name        String?
  email           String?
  isAdmin         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  subscription           Subscription?
  templatesCreated       Template[]         @relation("TemplateCreator")
  templatesOwned         TemplateOwnership[]
  breachReports          BreachReport[]     @relation("BreachReporter")
  breachesAgainst        BreachReport[]     @relation("BreachTarget")
  verificationRequests   TemplateVerification[] @relation("VerificationRequester")
  verificationReviews    TemplateVerification[] @relation("Reviewer")
  sessions               Session[]
  reputationTags         ReputationTag[]
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Subscription {
  id        String           @id @default(cuid())
  userId    String           @unique
  tier      SubscriptionTier @default(FREE)
  startedAt DateTime         @default(now())
  expiresAt DateTime?
  
  // Payment tracking
  lastPaymentTx String?
  lastPaymentAt DateTime?
  
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum SubscriptionTier {
  FREE
  POWER_USER
}

// ============================================================
// TEMPLATE MARKETPLACE
// ============================================================

model Template {
  id            String   @id @default(cuid())
  onChainId     String?  @unique // Asset Hub NFT ID
  creatorId     String
  
  // Content
  title         String
  description   String
  content       String   @default("") // Template body text
  category      TemplateCategory
  ipfsCid       String   // Encrypted content on IPFS
  previewCid    String?  // Public preview on IPFS
  placeholders  String   @default("[]") // JSON array of placeholder definitions
  
  // Pricing
  price         Float    @default(0)
  currency      String   @default("DOCU")
  royaltyPercent Float   @default(10)
  
  // Stats
  salesCount    Int      @default(0)
  totalRevenue  Float    @default(0)
  
  // Status
  isListed      Boolean  @default(false)
  isVerified    Boolean  @default(false)
  mintedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  creator       User     @relation("TemplateCreator", fields: [creatorId], references: [id])
  verification  TemplateVerification?
  owners        TemplateOwnership[]
  purchases     Purchase[]
}

enum TemplateCategory {
  LEGAL
  CREATIVE
  ENGINEERING
}

model TemplateOwnership {
  id         String   @id @default(cuid())
  templateId String
  userId     String
  purchasedAt DateTime @default(now())
  txHash     String?
  
  template   Template @relation(fields: [templateId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  
  @@unique([templateId, userId])
}

model Purchase {
  id              String   @id @default(cuid())
  templateId      String
  buyerAddress    String
  sellerAddress   String
  buyerId         String?  // Linked user if known
  sellerId        String?  // Linked user if known
  
  // THE IRON RULES - 75/20/5 Split
  totalPrice      Float    @default(0)
  price           Float    @default(0) // Alias for totalPrice
  creatorAmount   Float    @default(0) // 75%
  companyAmount   Float    @default(0) // 20%
  burnAmount      Float    @default(0) // 5%
  status          String   @default("COMPLETED")
  
  // Transaction
  txHash          String?  @unique
  blockNumber     Int?
  timestamp       DateTime @default(now())
  createdAt       DateTime @default(now())
  
  template        Template @relation(fields: [templateId], references: [id])
}

// ============================================================
// VERIFICATION SYSTEM ("Blue Check")
// ============================================================

model TemplateVerification {
  id           String               @id @default(cuid())
  templateId   String               @unique
  requesterId  String?              // User who requested verification
  
  // Request
  status      VerificationStatus   @default(PENDING)
  requestedAt DateTime             @default(now())
  createdAt   DateTime             @default(now())
  
  // Payment ($50-$100 fee)
  feePaid     Float?
  paymentTx   String?
  
  // Review
  reviewerId  String?
  reviewedAt  DateTime?
  auditLog    String?              // Admin notes
  feedback    String?              // Rejection reason
  
  // Credential (if approved)
  credentialHash String?           // KILT credential hash
  
  template    Template             @relation(fields: [templateId], references: [id])
  requester   User?                @relation("VerificationRequester", fields: [requesterId], references: [id])
  reviewer    User?                @relation("Reviewer", fields: [reviewerId], references: [id])
}

enum VerificationStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
}

// ============================================================
// BREACH MANAGEMENT (Reputation Enforcement)
// ============================================================

model BreachReport {
  id            String        @id @default(cuid())
  
  // Parties
  reporterId    String
  targetId      String        // User being reported
  
  // Contract Reference
  contractHash  String?       // POC hash of the contract
  txHash        String?       // On-chain evidence
  
  // Report Details  
  reason        BreachReason
  description   String
  evidence      String?       // IPFS CID of supporting docs
  
  // Status
  status        BreachStatus  @default(PENDING)
  severity      BreachSeverity?
  
  // Review
  reviewedBy    String?
  reviewedAt    DateTime?
  resolution    String?
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  reporter      User          @relation("BreachReporter", fields: [reporterId], references: [id])
  target        User          @relation("BreachTarget", fields: [targetId], references: [id])
}

enum BreachReason {
  NON_DELIVERY
  QUALITY_ISSUE
  PAYMENT_DISPUTE
  CONFIDENTIALITY_BREACH
  FRAUD
  OTHER
}

enum BreachStatus {
  PENDING
  INVESTIGATING
  CONFIRMED
  DISMISSED
  APPEALED
}

enum BreachSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ============================================================
// DYNAMIC REPUTATION TAGGING
// ============================================================

model ReputationTag {
  id        String   @id @default(cuid())
  userId    String
  
  // Tag derived from on-chain activity
  tag       String   // e.g., "Smart Contract Dev", "Legal Expert"
  source    TagSource
  
  // Evidence
  txHash    String?  // Transaction that generated this tag
  pocHash   String?  // POC-1 hash reference
  value     Float?   // Contract value if relevant
  
  // Metadata
  issuedAt  DateTime @default(now())
  expiresAt DateTime? // Some tags may expire
  
  user      User     @relation(fields: [userId], references: [id])
  
  @@index([userId, tag])
}

enum TagSource {
  POC_COMPLETION   // Derived from completed POC
  TEMPLATE_SALES   // High seller volume
  VERIFICATION     // Verified creator
  MANUAL           // Admin-assigned
  BREACH           // Negative tag from breach
}

// ============================================================
// ADMIN AUDIT LOG
// ============================================================

model AdminLog {
  id            String   @id @default(cuid())
  adminId       String   @default("")
  adminAddress  String   @default("") // Wallet address of admin
  action        String   // e.g., "VERIFY_TEMPLATE", "CONFIRM_BREACH"
  targetType    String   @default("") // e.g., "Template", "User", "BreachReport"
  targetId      String
  details       String?  // JSON of action details
  createdAt     DateTime @default(now())
  
  @@index([adminId, createdAt])
  @@index([targetType, targetId])
}

// ============================================================
// INDEXER STATE (for chain sync)
// ============================================================

model IndexerState {
  id              String   @id @default("main")
  lastBlockNumber Int      @default(0)
  lastBlockHash   String?
  chainId         String   @default("asset-hub-westend")
  updatedAt       DateTime @updatedAt
}
