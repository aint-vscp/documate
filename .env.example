# Database
# Local development (legacy sqlite note)
DATABASE_URL="file:./dev.db"
# Current prisma/schema.prisma uses provider=postgresql, so local dev should also use a PostgreSQL URL.
# Production (Vercel) - replace with your Vercel Postgres or Neon connection string
# DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# App URLs
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
NEXTAUTH_URL="https://your-app.vercel.app"
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# Blockchain - Polkadot Hub Testnet
POLKADOT_HUB_RPC_URL="https://eth-rpc-testnet.polkadot.io/"
NEXT_PUBLIC_CHAIN_ID="420420417"
NEXT_PUBLIC_DOCUMATE_CONTRACT_ADDRESS="0x233FE6112E5Ad4Db1c83358B30D581F837314BB1"
MARKETPLACE_CONTRACT_ADDRESS="0x233FE6112E5Ad4Db1c83358B30D581F837314BB1"
STAKING_CONTRACT_ADDRESS="0x1cf190eabe490B50AaBE91b4567ebe88126e8D24"
DOCUMATE_NETWORK="testnet"

# Contract owner keys - never commit real values
PRIVATE_KEY="0xYOUR_TESTNET_PRIVATE_KEY"
ADMIN_PRIVATE_KEY="0xYOUR_TESTNET_PRIVATE_KEY"

# KILT Identity
KILT_DAPP_DID="did:kilt:your-app-did"
KILT_DAPP_MNEMONIC="word1 word2 ... word12"
