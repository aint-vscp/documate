# ━━━━━━━━━━━━━━━━━━━━━━━━
# DATABASE
# ━━━━━━━━━━━━━━━━━━━━━━━━
# Prisma provider is postgresql. Get from neon.tech project connection string.
DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# ━━━━━━━━━━━━━━━━━━━━━━━━
# BLOCKCHAIN
# ━━━━━━━━━━━━━━━━━━━━━━━━
# Working Polkadot Hub testnet RPC.
POLKADOT_HUB_RPC_URL="https://eth-rpc-testnet.polkadot.io/"
# Live testnet contracts (update if redeployed).
NEXT_PUBLIC_DOCUMATE_CONTRACT_ADDRESS="0x233FE6112E5Ad4Db1c83358B30D581F837314BB1"
MARKETPLACE_CONTRACT_ADDRESS="0x233FE6112E5Ad4Db1c83358B30D581F837314BB1"
STAKING_CONTRACT_ADDRESS="0x1cf190eabe490B50AaBE91b4567ebe88126e8D24"
NEXT_PUBLIC_CHAIN_ID="420420417"
NEXT_PUBLIC_CHAIN_ID_HEX="0x190f1b41"
DOCUMATE_NETWORK="testnet"

# Optional deploy/script overrides.
# TREASURY_ADDRESS defaults to deployer if empty.
TREASURY_ADDRESS=""
# BURN_ADDRESS default is dead address if unset.
BURN_ADDRESS="0x000000000000000000000000000000000000dEaD"
# IDENTITY_PRECOMPILE default points to KILT precompile.
IDENTITY_PRECOMPILE="0x0000000000000000000000000000000000000818"
# false = live verification path, true = mock verification.
USE_MOCK_VERIFICATION="false"
# Optional fallback wallet address used in checks if PRIVATE_KEY is unavailable.
TEST_WALLET_ADDRESS=""

# ━━━━━━━━━━━━━━━━━━━━━━━━
# CONTRACT OWNER — NEVER COMMIT
# ━━━━━━━━━━━━━━━━━━━━━━━━
# Export from MetaMask account that owns deployed contracts.
PRIVATE_KEY="0xPASTE_OWNER_PRIVATE_KEY"
ADMIN_PRIVATE_KEY="0xPASTE_OWNER_PRIVATE_KEY"

# ━━━━━━━━━━━━━━━━━━━━━━━━
# NEXTAUTH
# ━━━━━━━━━━━━━━━━━━━━━━━━
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="GENERATE_BASE64_32B_SECRET"
# Local dev URL.
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Public canonical site URL for metadata/links.
NEXT_PUBLIC_SITE_URL="https://your-app.vercel.app"
# Runtime mode (development locally, production on deployment).
NODE_ENV="development"

# ━━━━━━━━━━━━━━━━━━━━━━━━
# KILT IDENTITY
# ━━━━━━━━━━━━━━━━━━━━━━━━
# Generate with @polkadot/util-crypto mnemonicGenerate().
KILT_DAPP_MNEMONIC="word1 word2 ... word12"
# Create DID with: npm run kilt:create-did
KILT_DAPP_DID="did:kilt:PENDING_CREATION"
# Dwellir managed API key used by the DID script for wss://api-kilt.dwellir.com/<key>
DWELLIR_KILT_API_KEY="YOUR_DWELLIR_KILT_API_KEY"
# Primary (Spiritnet production via Dwellir - most reliable)
KILT_WSS_ENDPOINT="wss://kilt-rpc.dwellir.com"
# Fallback options if primary is down:
# KILT_WSS_ENDPOINT="wss://spiritnet.kilt.io"
# KILT_WSS_ENDPOINT="wss://spiritnet.api.onfinality.io/public-ws"
# Status page: https://status.kilt.io
